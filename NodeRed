  {
    "id": "awb_extract_ics_url",
    "type": "function",
    "z": "tab_awb_standalone",
    "name": "ICS-URL aus HTML extrahieren",
    "func": "const html = msg.payload;\n\n// ICS-URL per Regex finden (href mit t=ics oder .ics)\nconst match = html.match(/href=\"([^\"]*(?:t=ics|\\.ics)[^\"]*)\"/i);\n\nif (!match) {\n    node.error('Keine ICS-URL gefunden! Ort/Straße prüfen: ' + msg.awb_city + ' / ' + msg.awb_street);\n    node.send([null, { payload: '❌ Fehler: Keine ICS-URL – Ort/Straße prüfen!' }]);\n    return null;\n}\n\nlet icsUrl = match[1];\nif (!icsUrl.startsWith('http')) {\n    icsUrl = 'https://www.awb-es.de' + (icsUrl.startsWith('/') ? '' : '/') + icsUrl;\n}\n\nnode.warn('ICS-URL: ' + icsUrl);\nmsg.url = icsUrl;\nreturn [msg, null];",
    "outputs": 2,
    "noerr": 0,
    "x": 430,
    "y": 280,
    "wires": [
