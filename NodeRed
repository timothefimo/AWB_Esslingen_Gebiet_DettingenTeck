  {
    "id": "awb_save_context",
    "type": "function",
    "z": "tab_awb_standalone",
    "name": "In ioBroker Datenpunkte schreiben (optional)",
    "func": "// Schreibt die Werte auch in ioBroker-Datenpunkte (0_userdata.0)\n// → Damit können Blockly/JS-Skripte die Werte nutzen\n// → Auskommentieren wenn nicht gewünscht\n\nconst result = msg.awb_result;\nconst msgs   = [];\n\nfor (const [id, r] of Object.entries(result)) {\n    msgs.push({ topic: `0_userdata.0.Muell.${id}.naechsterTermin`, payload: r.termin });\n    msgs.push({ topic: `0_userdata.0.Muell.${id}.tageVerbleibend`, payload: r.tage });\n    msgs.push({ topic: `0_userdata.0.Muell.${id}.abholungHeute`,   payload: r.heute });\n    msgs.push({ topic: `0_userdata.0.Muell.${id}.abholungMorgen`,  payload: r.morgen });\n}\n\n// Jeden State einzeln senden\nfor (const m of msgs) {\n    node.send(m);\n}\nreturn null;",
    "outputs": 1,
    "noerr": 0,
    "x": 700,
    "y": 440,
    "wires": [
