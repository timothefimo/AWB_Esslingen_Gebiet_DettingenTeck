    "id": "awb_config",
    "type": "function",
    "z": "tab_awb_standalone",
    "name": "⚙️ KONFIGURATION",
    "func": "// ============================================================\n// HIER DEINE ADRESSE EINTRAGEN\n// ============================================================\nmsg.awb_city   = 'Dettingen unter Teck';  // Ort\nmsg.awb_street = 'Am Kelterplatz';         // Straße\n\n// Abfalltypen mit exakten ICS-Schlüsselwörtern (AWB Esslingen)\nmsg.awb_types = [\n    { id: 'restmuell',  name: 'Restmüll',    icon: '🗑️', color: '#616161', keywords: ['restmüll', 'restabfall'] },\n    { id: 'biomuell',   name: 'Biomüll',     icon: '🟫', color: '#5D4037', keywords: ['biotonne', 'biomüll'] },\n    { id: 'papier',     name: 'Papier',      icon: '📄', color: '#1565C0', keywords: ['papiertonne', 'papier'] },\n    { id: 'gelberSack', name: 'Gelber Sack', icon: '🟡', color: '#F9A825', keywords: ['gelbe/r sack/tonne', 'gelber sack', 'gelbe tonne'] },\n];\n// ============================================================\n\nreturn msg;",
