  {
    "id": "awb_parse_ics",
    "type": "function",
    "z": "tab_awb_standalone",
    "name": "ICS parsen & Termine berechnen",
    "func": "const icsText  = msg.payload;\nconst types    = msg.awb_types;\n\n// ── ICS parsen ─────────────────────────────────────────────\nconst events = [];\nconst lines  = icsText.replace(/\\r\\n/g, '\\n').replace(/\\r/g, '\\n').split('\\n');\nlet inEvent  = false;\nlet current  = {};\n\nfor (const line of lines) {\n    const t = line.trim();\n    if (t === 'BEGIN:VEVENT') { inEvent = true; current = {}; continue; }\n    if (t === 'END:VEVENT') {\n        inEvent = false;\n        if (current.summary && current.date) {\n            // WICHTIG: Datum LOKAL parsen (Fix Zeitzonenproblem UTC vs MESZ)\n            const [y, m, d] = current.date.split('-').map(Number);\n            const localDate  = new Date(y, m - 1, d, 0, 0, 0, 0);\n            events.push({\n                summary: current.summary,\n                date:    current.date,\n                ts:      localDate.getTime(),\n                dateObj: localDate,\n            });\n        }\n        continue;\n    }\n    if (!inEvent) continue;\n    if (t.startsWith('SUMMARY:'))  current.summary = t.substring(8).trim();\n    if (t.startsWith('DTSTART')) {\n        const raw = t.split(':').slice(1).join(':').trim().substring(0, 8);\n        if (/^\\d{8}$/.test(raw)) {\n            current.date = `${raw.substring(0,4)}-${raw.substring(4,6)}-${raw.substring(6,8)}`;\n        }\n    }\n}\nevents.sort((a, b) => a.ts - b.ts);\n\n// ── Nur heutige + zukünftige Termine ──────────────────────\nconst heute   = new Date();\nheute.setHours(0, 0, 0, 0);\nconst heuteTs = heute.getTime();\nconst upcoming = events.filter(e => e.ts >= heuteTs);\n\n// ── Für jeden Typ nächsten Termin finden ──────────────────\nconst result = {};\nfor (const wt of types) {\n    const match = upcoming.find(e =>\n        wt.keywords.some(kw => e.summary.toLowerCase().includes(kw))\n    );\n    if (match) {\n        const tage = Math.round((match.ts - heuteTs) / 86400000);\n        result[wt.id] = {\n            ...wt,\n            termin:  match.dateObj.toLocaleDateString('de-DE', { day:'2-digit', month:'2-digit', year:'numeric' }),\n            tage:    tage,\n            heute:   tage === 0,\n            morgen:  tage === 1,\n            summary: match.summary,\n        };\n    } else {\n        result[wt.id] = { ...wt, termin: 'Kein Termin', tage: -1, heute: false, morgen: false, summary: '' };\n    }\n}\n\nmsg.awb_result  = result;\nmsg.awb_count   = events.length;\nmsg.awb_upcoming = upcoming.length;\n\nnode.warn(`${events.length} Termine geladen, ${upcoming.length} zukünftig`);\nfor (const wt of types) {\n    const r = result[wt.id];\n    node.warn(`${wt.name}: ${r.termin} (${r.tage}d) – ${r.summary}`);\n}\n\nreturn msg;",
    "outputs": 1,
    "noerr": 0,
    "x": 430,
    "y": 380,
    "wires": [
      [
        "awb_build_dashboard",
        "awb_save_context"
      ]
    ]
